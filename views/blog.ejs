<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="container mt-4">
      <h1><%= blog.title %></h1>
      <img
        src="<%= blog.coverImageURL %>"
        class="card-img-top"
        alt="<%= blog.title %>"
        style="height: 320px; object-fit: cover"
      />

      <p class="mt-4"><%= blog.body %></p>
    </div>

    <%- include('./partials/script') %>
  </body>
</html>
